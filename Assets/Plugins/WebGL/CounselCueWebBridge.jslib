let css=document.createElement("style");css.textContent="#cci{position:fixed;z-index:60;left:50%;bottom:16px;transform:translateX(-50%);width:min(65vw,1040px);display:none;flex-direction:column;gap:6px;font-family:'Malgun Gothic',sans-serif}#ccf{box-sizing:border-box;width:100%;height:38px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;border-left:4px solid #a7d4bb;border-radius:10px;background:#0d1b18ee;color:#eef8f1;padding:8px 14px;font-size:17px;line-height:22px;box-shadow:0 6px 18px #0004}#cccontrols{display:flex;gap:8px;width:100%}#cci textarea{flex:1;min-width:0;height:58px;resize:none;box-sizing:border-box;border:2px solid #a7d4bb;border-radius:14px;background:#faf8f2;padding:13px 16px;font-size:17px;outline:none;box-shadow:0 8px 28px #0005}.ccb{height:58px;border:0;border-radius:14px;padding:0 17px;background:#347a5d;color:#fff;font-size:16px;font-weight:700}.mic{background:#835b50}.mic.on{background:#b84d4d;box-shadow:0 0 0 7px #b84d4d44}#ccn{position:static;flex:0 0 154px;align-self:center;box-sizing:border-box;color:#fff;background:#173b30ee;border-radius:14px;padding:7px 10px;font-size:11px;line-height:1.35;text-align:center}#cch{position:fixed;z-index:61;left:50%;top:12px;transform:translateX(-50%);border:1px solid #fff7;border-radius:20px;background:#173b30ee;color:#fff;padding:7px 12px;font-weight:700}#cct{position:fixed;inset:0;z-index:100;display:none;font-family:'Malgun Gothic',sans-serif;pointer-events:none}#ccs{position:fixed;border:3px solid #f3c778;border-radius:18px;box-shadow:0 0 28px #f3c778;transition:.25s}#ccp{position:fixed;width:370px;max-width:calc(100vw - 32px);box-sizing:border-box;background:#faf6ec;border-radius:18px;padding:20px 22px;box-shadow:0 16px 46px #0007;pointer-events:auto}#ccp h3{margin:0 0 8px;color:#245e47}#ccp p{line-height:1.5}.ctb{border:0;border-radius:9px;padding:9px 13px;font-weight:700}.next{float:right;background:#347a5d;color:white}:fullscreen #unity-container{left:0;top:0;transform:none;width:100vw;height:100vh;background:#1f1f20}:fullscreen #unity-canvas{width:100vw!important;height:100vh!important}:fullscreen #unity-footer{display:none}@media(max-width:800px){#cci{width:calc(100vw - 18px);bottom:8px}#ccn{display:none}.ccb{padding:0 10px}.lbl{display:none}}";document.head.appendChild(css);let f=document.querySelector("#unity-fullscreen-button");if(f)f.addEventListener("click",e=>{if(!document.documentElement.requestFullscreen)return;e.preventDefault();e.stopImmediatePropagation();document.documentElement.requestFullscreen().catch(x=>console.warn("CounselCue fullscreen failed",x))},true);
let r=document.createElement("div");r.id="cci";r.innerHTML='<div id="ccf">상담자의 언어·비언어 전달을 함께 관찰합니다.</div><div id="cccontrols"><span id="ccn">AI 생성 내담자 음성 · 원음 미저장</span><textarea placeholder="응답을 입력하거나 마이크를 누르세요…"></textarea><button class="ccb mic">● <span class="lbl">말하기</span></button><button class="ccb send">응답하기</button></div>';document.body.appendChild(r);S.r=r;S.x=r.querySelector("textarea");S.f=r.querySelector("#ccf");let m=r.querySelector(".mic"),b=r.querySelector(".send"),ch=()=>SendMessage(S.o,"OnWebTextChanged",S.x.value),go=()=>{let v=S.x.value.trim();if(S.on&&v)SendMessage(S.o,"OnWebTextSubmitted",v)};S.x.oninput=ch;S.x.onkeydown=e=>{if(e.key=="Enter"&&!e.shiftKey&&!e.isComposing){e.preventDefault();go()}};b.onclick=go;S.place=()=>{let c=canvas.getBoundingClientRect();Object.assign(r.style,{left:c.left+c.width/2+"px",bottom:innerHeight-c.bottom+12+"px",width:Math.max(320,Math.min(c.width-24,1040))+"px"})};addEventListener("resize",S.place);document.addEventListener("fullscreenchange",()=>setTimeout(S.place,0));S.place();
let R=window.SpeechRecognition||window.webkitSpeechRecognition;if(R){let q=new R();q.lang="ko-KR";q.interimResults=true;q.onstart=()=>m.classList.add("on");q.onresult=e=>{let t="";for(let j=e.resultIndex;j<e.results.length;j++)t+=e.results[j][0].transcript;S.x.value=t;ch()};q.onend=()=>{m.classList.remove("on");S.x.focus()};q.onerror=()=>m.classList.remove("on");m.onclick=()=>{try{q.start()}catch(e){q.stop()}}}else{m.disabled=true;m.title="Chrome 또는 Edge를 사용하세요."}
let t=document.createElement("div");t.id="cct";t.innerHTML='<div id="ccs"></div><div id="ccp"><h3></h3><p></p><button class="ctb skip">건너뛰기</button><button class="ctb next">다음</button></div>';document.body.appendChild(t);let h=document.createElement("button");h.id="cch";h.textContent="? 사용 안내";document.body.appendChild(h);let sp=t.querySelector("#ccs"),p=t.querySelector("#ccp"),nx=t.querySelector(".next"),cr=()=>canvas.getBoundingClientRect(),area=(lx,ly,lw,lh)=>{let z=cr();return[z.left+z.width*lx,z.top+z.height*ly,z.width*lw,z.height*lh]},er=e=>{let z=e.getBoundingClientRect();return[z.left,z.top,z.width,z.height]},ss=[["내담자의 표정과 자세를 관찰하세요","얼굴 근육, 시선, 움직임과 말의 내용을 함께 보세요.",()=>area(.31,.12,.38,.56)],["관찰 줌을 활용하세요","오른쪽 줌 컨트롤로 표정과 제스처를 가까이 확인하세요.",()=>area(.78,.24,.205,.08)],["한글 입력을 지원합니다","한글 조합, 붙여넣기, Shift+Enter 줄바꿈이 가능합니다.",()=>er(S.x)],["마이크로 응답하세요","최초 1회 브라우저 마이크 권한 승인이 필요합니다.",()=>er(m)],["감정 음성으로 답합니다","LLM 페르소나 답변이 ElevenLabs 음성으로 재생됩니다.",()=>er(b)]];
let draw=()=>{let s=ss[S.i],z=s[2]();Object.assign(sp.style,{left:z[0]-7+"px",top:z[1]-7+"px",width:z[2]+14+"px",height:z[3]+14+"px"});p.querySelector("h3").textContent=s[0];p.querySelector("p").textContent=s[1];p.style.left=Math.min(Math.max(16,z[0]+z[2]/2-185),innerWidth-386)+"px";let cardHeight=p.offsetHeight||190,below=z[1]+z[3]+20,above=z[1]-cardHeight-20;p.style.top=Math.max(16,Math.min(below+cardHeight+16<=innerHeight?below:above,innerHeight-cardHeight-16))+"px";nx.textContent=S.i==4?"시작하기":"다음";t.style.display="block"},close=()=>{t.style.display="none";localStorage.setItem("counselcue-tour-v2","done")};nx.onclick=()=>{if(++S.i>4)close();else draw()};t.querySelector(".skip").onclick=close;h.onclick=()=>{S.i=0;draw()};S.show=()=>{if(!localStorage.getItem("counselcue-tour-v2")){S.i=0;draw()}};
},
CounselCueWeb_SetEnabled:function(v){let S=window.CounselCueWeb;if(!S)return;S.on=!!v;S.r.style.display=S.on?"flex":"none";if(S.on){S.place();S.x.focus();setTimeout(S.show,400)}},
CounselCueWeb_SetText:function(p){let S=window.CounselCueWeb;if(S)S.x.value=UTF8ToString(p)},
CounselCueWeb_SetFeedback:function(p){let S=window.CounselCueWeb;if(!S)return;let d=document.createElement("div");d.innerHTML=UTF8ToString(p);let v=d.textContent||"";S.f.textContent=v;S.f.title=v},
CounselCueWeb_Speak:function(tp,ep){let S=window.CounselCueWeb;if(!S||!S.a)return;let notify=n=>SendMessage(S.o,n,""),clean=()=>{if(S.auUrl)URL.revokeObjectURL(S.auUrl);S.auUrl="";S.au=null};if(S.au){S.au.onended=null;S.au.onerror=null;S.au.pause();clean();notify("OnWebVoiceEnded")}let failed=false,fail=e=>{if(failed)return;failed=true;if(e)console.warn(e);clean();notify("OnWebVoiceFailed")};fetch(S.a+"/voice",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({text:UTF8ToString(tp),emotion:UTF8ToString(ep)})}).then(r=>{if(!r.ok)throw Error(r.status);return r.blob()}).then(x=>{let u=URL.createObjectURL(x),a=new Audio(u);S.au=a;S.auUrl=u;a.onplay=()=>notify("OnWebVoiceStarted");a.onended=()=>{clean();notify("OnWebVoiceEnded")};a.onerror=()=>fail(Error("audio playback failed"));a.play().catch(fail)}).catch(fail)}
});