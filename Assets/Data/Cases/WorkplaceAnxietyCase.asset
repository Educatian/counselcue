  m_Name: WorkplaceAnxietyCase
  m_EditorClassIdentifier: Assembly-CSharp::AdieLab.AffectCounsel.CounselingCaseDefinition
  caseId: workplace-anxiety-01
  caseTitle: "\uC9C1\uC7A5 \uBD88\uC548"
  clientName: "\uAE40\uC9C0\uD61C"
  clientProfile: "32\uC138 \xB7 \uCD08\uAE30\uBA74\uB2F4"
  presentingConcern: "\uCD5C\uADFC \uD68C\uC0AC\uC5D0 \uAC00\uB824\uACE0 \uD558\uBA74
    \uC228\uC774 \uB9C9\uD788\uACE0, \uC790\uC2E0\uC774 \uC57D\uD55C \uC0AC\uB78C\uC778\uC9C0
    \uAC71\uC815\uD569\uB2C8\uB2E4."
  initialClientLine: "\uC694\uC998 \uD68C\uC0AC\uC5D0 \uAC00\uB824\uACE0 \uD558\uBA74
    \uC228\uC774 \uB9C9\uD788\uB294 \uAC83 \uAC19\uC544\uC694.\n\uC81C\uAC00 \uB108\uBB34
    \uC57D\uD55C \uC0AC\uB78C\uC778\uAC00 \uC2F6\uAE30\uB3C4 \uD558\uACE0\uC694."
  fullSessionSeconds: 900
  focusedPracticeSeconds: 180
  focusedTargetTurns: 3
  learningObjectives:
  - "\uAD00\uACC4 \uC548\uC804\uAC10\uC744 \uD615\uC131\uD558\uACE0 \uC0C1\uB2F4
    \uAD6C\uC870\uB97C \uC548\uB0B4\uD569\uB2C8\uB2E4."
  - "\uBC18\uC601\uACFC \uAC1C\uBC29\uD615 \uC9C8\uBB38\uC73C\uB85C \uACBD\uD5D8\uC744
    \uD0D0\uC0C9\uD569\uB2C8\uB2E4."
  - "\uD574\uACB0\uCC45\uC744 \uC11C\uB450\uB974\uC9C0 \uC54A\uACE0 \uB0B4\uB2F4\uC790\uC758
    \uC751\uB2F5 \uACF5\uAC04\uC744 \uC9C0\uD0B5\uB2C8\uB2E4."
  disclosureLadder:
  - supportiveReply: "\uC81C\uAC00 \uC694\uC998 \uACC4\uC18D \uAE34\uC7A5\uD55C \uCC44\uB85C
      \uC9C0\uB0C8\uB358 \uAC83 \uAC19\uC544\uC694. \uB204\uAD70\uAC00\uC5D0\uAC8C
      \uB9D0\uD558\uB2C8 \uC870\uAE08 \uC815\uB9AC\uAC00 \uB418\uB294 \uB290\uB08C\uC774\uC5D0\uC694."
    guardedReply: "\uAE00\uC384\uC694\u2026 \uADF8\uB0E5 \uC81C\uAC00 \uC54C\uC544\uC11C
      \uD574\uC57C \uD558\uB294 \uBB38\uC81C \uAC19\uAE30\uB3C4 \uD574\uC694."
  - supportiveReply: "\uADF8 \uB9D0\uC744 \uB4E4\uC73C\uB2C8 \uC81C\uAC00 \uB108\uBB34
      \uC608\uBBFC\uD55C \uC0AC\uB78C\uC740 \uC544\uB2CC \uAC83 \uAC19\uC544\uC11C
      \uC870\uAE08 \uC548\uC2EC\uB3FC\uC694."
    guardedReply: "\uADF8\uB807\uAC8C \uAC04\uB2E8\uD788 \uD574\uACB0\uB420 \uBB38\uC81C\uC600\uC73C\uBA74
      \uC774\uBBF8 \uD588\uC744 \uAC83 \uAC19\uC544\uC694."
  - supportiveReply: "\uD68C\uC0AC\uC5D0 \uB4E4\uC5B4\uAC00\uB294 \uC21C\uAC04\uBD80\uD130
      \uAC00\uC2B4\uC774 \uB2F5\uB2F5\uD574\uC838\uC694. \uD2B9\uD788 \uD300\uC7A5\uB2D8\uACFC
      \uC774\uC57C\uAE30\uD560 \uB54C \uB354 \uC2EC\uD574\uC9C0\uACE0\uC694."
    guardedReply: "\uBB34\uC2A8 \uB9D0\uC744 \uD574\uC57C \uD560\uC9C0 \uC798 \uBAA8\uB974\uACA0\uC5B4\uC694."
  - supportiveReply: "\uC9C0\uB09C\uC8FC \uD68C\uC758\uC5D0\uC11C \uD300\uC7A5\uB2D8\uC774
      \uC0AC\uB78C\uB4E4 \uC55E\uC5D0\uC11C \uC81C \uC2E4\uC218\uB97C \uC9C0\uC801\uD588\uC5B4\uC694.
      \uADF8 \uB4A4\uB85C \uC2DC\uC120\uC774 \uC2E0\uACBD \uC4F0\uC5EC\uC694."
    guardedReply: "\uADF8 \uC598\uAE30\uB294 \uC544\uC9C1 \uC790\uC138\uD788 \uD558\uACE0
      \uC2F6\uC9C0 \uC54A\uC544\uC694."
  - supportiveReply: "\uB610 \uD2C0\uB9AC\uBA74 \uC5B4\uCA4C\uB098 \uC2F6\uC5B4\uC11C
      \uC791\uC740 \uC77C\uB3C4 \uACC4\uC18D \uD655\uC778\uD574\uC694. \uACB0\uAD6D
      \uC81C\uAC00 \uBD80\uC871\uD55C \uD0D3 \uAC19\uACE0\uC694."
    guardedReply: "\uACB0\uAD6D \uC81C\uAC00 \uC798\uBABB\uD55C \uAC83 \uAC19\uC544\uC11C
      \uB9D0\uD574\uB3C4 \uB2EC\uB77C\uC9C8 \uAC8C \uC788\uB098 \uC2F6\uC5B4\uC694."
  - supportiveReply: "\uC694\uC998\uC740 \uCD9C\uADFC \uC804\uBD80\uD130 \uD1F4\uC0AC\uD574\uC57C
      \uD558\uB098 \uC0DD\uAC01\uD574\uC694. \uADF8\uB807\uC9C0\uB9CC \uADF8\uB9CC\uB450\uB294
      \uAC83\uB3C4 \uAC81\uC774 \uB098\uC694."
    guardedReply: "\uD1F4\uC0AC \uC598\uAE30\uAE4C\uC9C0\uB294 \uD558\uACE0 \uC2F6\uC9C0
      \uC54A\uC544\uC694. \uB108\uBB34 \uC55E\uC11C\uAC00\uB294 \uAC83 \uAC19\uC544\uC694."
  - supportiveReply: "\uAC00\uC871\uC5D0\uAC8C\uB294 \uAC71\uC815\uC2DC\uD0AC\uAE4C
      \uBD10 \uB9D0\uD558\uC9C0 \uBABB\uD588\uC5B4\uC694. \uD63C\uC790 \uBC84\uD2F0\uB294
      \uAC8C \uC810\uC810 \uD798\uB4E4\uC5B4\uC694."
    guardedReply: "\uAC00\uC871\uC5D0\uAC8C\uB294 \uB9D0\uD558\uACE0 \uC2F6\uC9C0
      \uC54A\uC544\uC694. \uAC71\uC815\uB9CC \uB354\uD560 \uD14C\uB2C8\uAE4C\uC694."
  - supportiveReply: "\uC81C\uAC00 \uC6D0\uD558\uB294 \uAC74 \uB2F9\uC7A5 \uB2F5\uC744
      \uC815\uD558\uB294 \uAC83\uBCF4\uB2E4 \uC548\uC804\uD558\uAC8C \uC77C\uD560
      \uC218 \uC788\uB2E4\uB294 \uB290\uB08C\uC778 \uAC83 \uAC19\uC544\uC694."
    guardedReply: "\uC81C\uAC00 \uBB34\uC5C7\uC744 \uC6D0\uD558\uB294\uC9C0\uB294
      \uC798 \uBAA8\uB974\uACA0\uC5B4\uC694. \uADF8\uB0E5 \uB35C \uD798\uB4E4\uC5C8\uC73C\uBA74
      \uC88B\uACA0\uC5B4\uC694."
  - supportiveReply: "\uC9C0\uAE08 \uC815\uB9AC\uD574 \uC8FC\uC2E0 \uB0B4\uC6A9\uC744
      \uB4E4\uC73C\uB2C8 \uC81C\uAC00 \uBB34\uC5C7 \uB54C\uBB38\uC5D0 \uD798\uB4E0\uC9C0
      \uC870\uAE08 \uB354 \uC120\uBA85\uD574\uC84C\uC5B4\uC694."
    guardedReply: "\uC815\uB9AC\uAC00 \uB410\uB294\uC9C0\uB294 \uBAA8\uB974\uACA0\uC5B4\uC694.
      \uC544\uC9C1 \uC870\uAE08 \uBD80\uB2F4\uC2A4\uB7EC\uC6CC\uC694."
  - supportiveReply: "\uB2E4\uC74C\uC5D0\uB294 \uBD88\uC548\uC774 \uC62C\uB77C\uC624\uB294
      \uC21C\uAC04\uC744 \uB354 \uC0B4\uD3B4\uBCF4\uACE0, \uC81C\uAC00 \uD560 \uC218
      \uC788\uB294 \uC791\uC740 \uC120\uD0DD\uB3C4 \uCC3E\uC544\uBCF4\uACE0 \uC2F6\uC5B4\uC694."
    guardedReply: "\uC624\uB298\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB9CC \uC774\uC57C\uAE30\uD558\uACE0
      \uC2F6\uC5B4\uC694."
  focusSkills:
  - id: emotion-reflection
    label: "\uAC10\uC815 \uBC18\uC601"
    objective: "\uAC10\uC815\uACFC \uC758\uBBF8\uB97C \uAD6C\uCCB4\uC801\uC73C\uB85C
      \uBC18\uC601\uD55C\uB2E4."
    coachingPrompt: "\uAC10\uC815 \uB2E8\uC5B4\uC640 \uADF8 \uC758\uBBF8\uB97C \uD55C
      \uBB38\uC7A5\uC5D0 \uB2F4\uC544 \uBCF4\uC138\uC694."
  - id: open-question
    label: "\uAC1C\uBC29\uD615 \uC9C8\uBB38"
    objective: "\uB0B4\uB2F4\uC790\uAC00 \uACBD\uD5D8\uC744 \uD655\uC7A5\uD558\uB3C4\uB85D
      \uC9C8\uBB38\uD55C\uB2E4."
    coachingPrompt: "\uC608\xB7\uC544\uB2C8\uC624\uB85C \uB05D\uB098\uC9C0 \uC54A\uB294
      \uC9C8\uBB38 \uB4A4 \uC751\uB2F5 \uACF5\uAC04\uC744 \uB0A8\uAE30\uC138\uC694."
  - id: delivery-alignment
    label: "\uC804\uB2EC \uC815\uD569"
    objective: "\uC5B8\uC5B4\uC640 \uD45C\uC815\xB7\uC2DC\uC120\uC758 \uC804\uB2EC\uC744
      \uB9DE\uCD98\uB2E4."
    coachingPrompt: "\uBB38\uC7A5 \uB0B4\uC6A9\uACFC \uC5BC\uAD74\uC758 \uAE34\uC7A5\xB7\uBBF8\uC18C\uAC00
      \uAC19\uC740 \uBA54\uC2DC\uC9C0\uC778\uC9C0 \uD655\uC778\uD558\uC138\uC694."
