    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 1
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\uC0C1\uD669\n\uCD5C\uADFC \uD68C\uC0AC\uC5D0 \uAC00\uB824\uACE0 \uD558\uBA74
    \uC228\uC774 \uB9C9\uD788\uACE0, \uC790\uC2E0\uC774 \uC57D\uD55C \uC0AC\uB78C\uC778\uC9C0
    \uAC71\uC815\uD569\uB2C8\uB2E4.\n\n\uC774\uBC88 \uC138\uC158\uC758 \uBAA9\uD45C\n1.
    \uAD00\uACC4 \uC548\uC804\uAC10\uC744 \uD615\uC131\uD558\uACE0 \uC0C1\uB2F4 \uAD6C\uC870\uB97C
    \uC548\uB0B4\uD569\uB2C8\uB2E4.\n2. \uBC18\uC601\uACFC \uAC1C\uBC29\uD615 \uC9C8\uBB38\uC73C\uB85C
    \uACBD\uD5D8\uC744 \uD0D0\uC0C9\uD569\uB2C8\uB2E4.\n3. \uD574\uACB0\uCC45\uC744
    \uC11C\uB450\uB974\uC9C0 \uC54A\uACE0 \uB0B4\uB2F4\uC790\uC758 \uC751\uB2F5 \uACF5\uAC04\uC744
    \uC9C0\uD0B5\uB2C8\uB2E4.\n\n15\uBD84 \xB7 \uBAA9\uD45C 10\uD134 \xB7 \uC6F9\uCEA0
    \uC6D0\uBCF8 \uBBF8\uC800\uC7A5"
